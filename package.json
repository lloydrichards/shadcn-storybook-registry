{
  "name": "shadcn-storybook-registry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "clean": "rm -rf .next public/storybook node_modules",
    "build": "next build && bun run storybook:build",
    "start": "next start",
    "lint": "biome lint",
    "test": "vitest run",
    "test:unit": "vitest run --project=unit",
    "test:storybook": "vitest run --project=storybook",
    "type-check": "tsc --noEmit",
    "format:write": "biome format --write",
    "format:check": "biome format",
    "release": "semantic-release",
    "registry:build": "bun run registry:build-radix && bun run registry:build-base && bun run registry:postbuild",
    "registry:build-radix": "shadcn build registry.radix.json -o ./public/v3/radix",
    "registry:build-base": "shadcn build registry.base.json -o ./public/v3/base",
    "registry:postbuild": "bun run scripts/registry-postbuild.ts",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o public/storybook",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@shadcn/react": "^0.2.0",
    "@tanstack/react-form": "^1.33.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.1",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.80.0",
    "react-resizable-panels": "^4.12.1",
    "recharts": "3.9.2",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "semantic-release": "^25.0.5",
    "storybook": "^10.4.6",
    "storybook-addon-test-codegen": "^3.0.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
